# Client (Vite) — copy to .env.local and fill in values.
# Only VITE_* variables are exposed to the browser.

# Backend API origin (production). Leave empty to use same-origin /api proxy.
VITE_API_URL=

# Google OAuth Web client ID (optional)
VITE_GOOGLE_CLIENT_ID=

# Dev only: Vite proxy target for /api (default http://127.0.0.1:5000)
VITE_DEV_API_PROXY=http://127.0.0.1:5000
