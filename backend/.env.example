# Server
NODE_ENV=development
PORT=5000

# Local JSON store (default: backend/data/store.json relative to backend package)
# DATA_PATH=./data/store.json

# Auth — use a long random string in production (32+ characters)
JWT_SECRET=change-me-to-a-long-random-secret-in-production
# Short-lived access JWT (default 15m). Legacy JWT_EXPIRES_IN is still read if JWT_ACCESS_EXPIRES_IN is unset.
JWT_ACCESS_EXPIRES_IN=15m
# JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_DAYS=7
BCRYPT_SALT_ROUNDS=12

# CORS — Vite default dev server; add production origins comma-separated if needed
CORS_ORIGIN=http://localhost:5173

# Public web URL (password reset links)
APP_PUBLIC_URL=http://localhost:5173

# Password reset token lifetime (minutes)
PASSWORD_RESET_EXPIRES_MIN=60

# Google Sign-In — Web client ID (must match VITE_GOOGLE_CLIENT_ID on the frontend)
GOOGLE_CLIENT_ID=

# Optional SMTP for password reset emails (otherwise dev logs link to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@example.com
